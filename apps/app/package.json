{
  "name": "@acumen/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c yellow,cyan \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --workspace @acumen/client run dev",
    "dev:server": "npm --workspace @acumen/server run dev",
    "build": "npm --workspace @acumen/shared run build && npm --workspace @acumen/client run build && npm --workspace @acumen/server run build",
    "db:generate": "npm --workspace @acumen/server run db:generate",
    "db:push": "npm --workspace @acumen/server run db:push",
    "db:studio": "npm --workspace @acumen/server run db:studio"
  }
}

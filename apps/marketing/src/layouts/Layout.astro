---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Acumen — Exam Intelligence for Cambridge Schools',
  description = 'Acumen turns Cambridge IGCSE and A Level result files into instant academic intelligence. Upload once. Understand everything.',
} = Astro.props;

const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:5173';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="app-url" content={APP_URL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; scroll-behavior: smooth; overflow-x: hidden; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #EDF1E7;
        color: #0A0A0B;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings: 'cv11', 'ss01', 'ss03';
        overflow-x: hidden;
        width: 100%;
      }
      img, svg { display: block; max-width: 100%; }
      a { color: inherit; text-decoration: none; }
      button { cursor: pointer; font-family: inherit; }
      input { font-family: inherit; }
      ::selection { background: #0A0A0B; color: #EDF1E7; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
